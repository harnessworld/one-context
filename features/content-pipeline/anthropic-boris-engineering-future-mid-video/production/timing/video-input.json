{
  "_comment": "wav-auto 可选配置。production 目录内需单个 .wav；音频放 production/media/（本地，勿提交）。",
  "wavFile": "media/voiceover.wav",
  "whisperModel": "small",
  "noSpeechThreshold": 0.85,
  "vadFilter": false,
  "strictSubtitles": false,
  "maxSubtitleGapSec": 2.5,
  "fillSrtGaps": true,
  "whisperHotwords": "Claude Anthropic Boris TypeScript Sequoia MCP Loop Salesforce Google Docs",
  "srtReplacements": [
    { "from": "Cloud Code", "to": "Claude Code", "ignoreCase": true }
  ],
  "wrapSubtitles": true,
  "outputFile": "final_auto.mp4",
  "burnSubtitles": true,
  "subtitle": {
    "fontSize": 52,
    "marginV": 14,
    "fontName": "Microsoft YaHei",
    "bold": true,
    "charsPerLine": 32,
    "primaryColour": "#FFFF00",
    "primaryAlpha": 108,
    "backAlpha": 255,
    "shadow": 0,
    "outline": 1,
    "barHeight": 110,
    "barAlpha": 0.65
  }
}
