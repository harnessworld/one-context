# 复制为 local.env（勿提交仓库）。格式：KEY=value（不要用引号包裹除非值内含空格）
# 同步到「用户级永久环境变量」：在仓库根执行
#   powershell -ExecutionPolicy Bypass -File skills/volc-podcast-tts/scripts/sync-user-env-from-local.ps1
# 若曾同步过错误的 APP_ID，先清空再写：同上命令末尾加 -ResetFirst

# 推荐（新版控制台「快速 API 接入」里点「复制」得到的长串密钥 → 放在这里）
VOLCENGINE_PODCAST_API_KEY=

# 旧版控制台仍可用：APP ID + Access Token（与 API_KEY 二选一，不要混填）
# VOLCENGINE_PODCAST_APP_ID=
# VOLCENGINE_PODCAST_ACCESS_KEY=

# VOLCENGINE_PODCAST_RESOURCE_ID=volc.service_type.10050
# VOLCENGINE_PODCAST_APP_KEY=
