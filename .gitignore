# Sub-repositories: not committed; see meta/repos.yaml and scripts/sync_repos.py
repos/research/*
!repos/research/.gitkeep
repos/develop/*
!repos/develop/.gitkeep

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Skills (local npm install under skills/)
skills/**/node_modules/

# Node (skills: html-video-from-slides CLI)
skills/html-video-from-slides/node_modules/
skills/html-video-from-slides/.cache/

# Feature production (cover toolchain)
features/develop/one-context-intro-short-video/production/node_modules/
features/develop/one-context-intro-short-video/production/temp_video_wav/

# Testing
.coverage
.pytest_cache/

# Local env (proxy, etc.); README "Network / HTTP proxy"
.env

# Video assets (large binaries; do not commit)
*.mp4
*.webm
*.mov
*.mkv
*.avi
*.m4v
*.wmv
*.flv
*.wav

# OS
.DS_Store
*.swp

# IDEs
.idea/
.vscode/

# Agent runtime (local, personal) — keep small project manifest committable
.openclaw/**
!.openclaw/onecxt-project.json
memory/*
!memory/.gitkeep
!memory/README.md

# Generated tool configs (run `onecxt adapt` locally)
# These are local-first: each developer generates their own
.cursor/rules/onecxt-*.mdc
.cursor/rules/agent-*.mdc
.claude/
CLAUDE.md
