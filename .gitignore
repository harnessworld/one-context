# Sub-repositories & optional external/ clones: not committed; see meta/repos.yaml and scripts/sync_repos.py
repos/**
!repos/**/.gitkeep

external/*
!external/README.md

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Node — all node_modules everywhere
**/node_modules/

# Node cache
skills/html-video-from-slides/.cache/

# Testing
.coverage
.pytest_cache/

# Local env (proxy, etc.); README "Network / HTTP proxy"
.env

# Features: production/ directories are build artifacts (covers, srt, JSON, node_modules, etc.)
features/**/production/

# Features: temporary build artifacts
features/**/temp_*/
features/**/scratch/
tmp/

# Ad-hoc scripts with _ prefix (fix, search, test, etc.)
_*_*.py
_*-*.txt
_search*.cjs

# Video media files (generated, not for repo)
*.mp4
*.webm
*.wav

# OS
.DS_Store
*.swp

# IDEs
.idea/
.vscode/

# Agent runtime (local, personal) — keep small project manifest committable
.openclaw/**
!.openclaw/onecxt-project.json
memory/*
!memory/.gitkeep
!memory/README.md

# Generated tool configs (run `onecxt adapt` locally)
# These are local-first: each developer generates their own
.cursor/rules/
!.cursor/rules/.gitkeep
.claude/
CLAUDE.md
