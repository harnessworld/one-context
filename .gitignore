# Sub-repositories & optional external/ clones: not committed; see meta/repos.yaml and scripts/sync_repos.py
repos/**
!repos/**/.gitkeep



# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Node — all node_modules everywhere
**/node_modules/

# Node (repo root / feature production sandboxes — do not commit)
node_modules/

# Node (skills: html-video-from-slides CLI)
skills/html-video-from-slides/node_modules/
skills/html-video-from-slides/.cache/

# Feature pipelines: local npm installs; wav/tts 中间文件（cli 写入 production/tmp/）
features/**/production/node_modules/
features/**/production/tmp/
# 旧版目录名，若本地仍有残留则继续忽略
features/**/production/temp_video_wav/
features/**/production/temp_video/

# Local CLI / scratch (repo root)
.opencli/
/_*.py
/_*.ps1
/_shots_*/
skills/.skills_store_lock.json

# Testing
.coverage
.pytest_cache/

# Local env (proxy, etc.); README "Network / HTTP proxy"
.env

# Features: production/ directories are build artifacts (covers, srt, JSON, node_modules, etc.)
features/**/production/

# Features: temporary build artifacts
features/**/temp_*/
features/**/scratch/
tmp/

# Ad-hoc scripts with _ prefix (fix, search, test, etc.)
_*_*.py
_*-*.txt
_search*.cjs

# Video media files (generated, not for repo)
*.mp4
*.webm
*.wav

# Backup files
*.bak
backups/

# Test screenshots & media
*.png
*.jpg
deck-slides/

# OS
.DS_Store
*.swp

# IDEs
.idea/
.vscode/

# Agent runtime (local, personal) — keep small project manifest committable
.openclaw/**
!.openclaw/onecxt-project.json
!.openclaw/agents/
!.openclaw/skills/
memory/*
!memory/.gitkeep
!memory/README.md

# Generated tool configs (run `onecxt adapt` locally)
# Tracked so all tools stay in sync from meta/agents.yaml
.cursor/rules/
.claude/agents/
.claude/adapters/
.claude/skills/
!.claude/skills/*.md
!CLAUDE.md

# External symlinks (point to other repos, not one-context assets)
.claude/commands/

# Tool runtime (Playwright MCP etc.)
.playwright-mcp/

# Hermes (adapt generated, tracked)
!.hermes/
!.hermes.md

# Personal Agent config files (not project context)
HEARTBEAT.md
IDENTITY.md
SOUL.md
USER.md
TOOLS.md
canvas-philosophy.md

# Skill parallel verify runtime output
.skill-parallel-verify/

# Local one-context config (sensitive word lists, etc.)
.onecxt/sensitive-words.yaml

# Claude Code local settings (personal, not shared)
.claude/settings.json
# Test screenshots
tester*-screenshot.png
