# Sub-repositories & optional external/ clones: not committed; see meta/repos.yaml and scripts/sync_repos.py
repos/**
!repos/**/.gitkeep

external/*
!external/README.md

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Skills (local npm install under skills/)
skills/**/node_modules/

# Node (repo root / feature production sandboxes — do not commit)
node_modules/

# Node (skills: html-video-from-slides CLI)
skills/html-video-from-slides/node_modules/
skills/html-video-from-slides/.cache/

# Feature pipelines: local npm installs and ffmpeg temp
features/**/production/node_modules/
features/**/production/temp_video_wav/

# Local CLI / scratch (repo root)
.opencli/
/_*.py
/_*.ps1
/_shots_*/
skills/.skills_store_lock.json

# Testing
.coverage
.pytest_cache/

# Local env (proxy, etc.); README "Network / HTTP proxy"
.env

# Video assets (large binaries; do not commit)
*.mp4
*.webm
*.mov
*.mkv
*.avi
*.m4v
*.wmv
*.flv
*.wav

# OS
.DS_Store
*.swp

# IDEs
.idea/
.vscode/

# Agent runtime (local, personal) — keep small project manifest committable
.openclaw/**
!.openclaw/onecxt-project.json
memory/*
!memory/.gitkeep
!memory/README.md

# Generated tool configs (run `onecxt adapt` locally)
# These are local-first: each developer generates their own
.cursor/rules/onecxt-*.mdc
.cursor/rules/agent-*.mdc
.claude/
!.claude/agents/
CLAUDE.md
